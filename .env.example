# Public entry authentication. Change these before deployment.
PUBLIC_USER=relay_user
PUBLIC_PASS=change_this_public_password

# Public ports exposed by the overseas server.
SOCKS_PORT=1080
HTTP_PORT=8080
TUNNEL_PORT=8443

# Two upstream static residential SOCKS5 proxies.
# Put only hostnames/IPs in *_HOST, without socks5://.
UPSTREAM_1_HOST=residential-a.example.com
UPSTREAM_1_PORT=1080
UPSTREAM_1_USER=upstream_user_a
UPSTREAM_1_PASS=upstream_password_a

UPSTREAM_2_HOST=residential-b.example.com
UPSTREAM_2_PORT=1080
UPSTREAM_2_USER=upstream_user_b
UPSTREAM_2_PASS=upstream_password_b

# Round-robin health behavior for the upstream nodes.
UPSTREAM_MAX_FAILS=2
UPSTREAM_FAIL_TIMEOUT=30s

# TLS tunnel settings. Keep proxy.local unless you regenerate certs with another name.
TLS_SERVER_NAME=proxy.local

# Used only when rendering the optional domestic/client GOST config.
SERVER_HOST=203.0.113.10
LOCAL_SOCKS_PORT=11080
CLIENT_CA_FILE=./ca.crt

# Runtime image and logging.
GOST_IMAGE=gogost/gost:latest
GOST_LOG_LEVEL=info
